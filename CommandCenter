<script>
  // DATES
  const today = new Date();
  const raceDate = new Date('2026-06-21');
  const yearEnd = new Date('2027-03-31');
  const yearStart = new Date('2026-04-05');

  const daysToRace = Math.ceil((raceDate - today) / (1000*60*60*24));
  const daysTotal = Math.ceil((yearEnd - yearStart) / (1000*60*60*24));
  const daysPassed = Math.ceil((today - yearStart) / (1000*60*60*24));
  const yearPct = Math.max(0, Math.min(100, Math.round(daysPassed / daysTotal * 100)));

  document.getElementById('days-to-race').textContent = Math.max(0, daysToRace);
  document.getElementById('days-year').textContent = daysTotal;
  document.getElementById('year-pct').textContent = yearPct + '%';
  document.getElementById('year-fill').style.width = yearPct + '%';

  const opts = { day: 'numeric', month: 'long', year: 'numeric' };
  document.getElementById('today-date').textContent = today.toLocaleDateString('ru-RU', opts);
  document.getElementById('entry-date').textContent = today.toLocaleDateString('ru-RU', opts);

  // SCORES
  const scores = { career: 7, sport: 8, mental: 6, family: 5 };

  function updateTotal() {
    const t = Object.values(scores).reduce((a,b) => a+b, 0);
    document.getElementById('v-total').textContent = t;
    const pct = t / 40;
    const el = document.getElementById('v-total');
    el.style.color = pct > 0.75 ? 'var(--green)' : pct > 0.5 ? 'var(--accent)' : 'var(--red)';
  }

  function changeScore(key, delta) {
    scores[key] = Math.max(1, Math.min(10, scores[key] + delta));
    document.getElementById('v-' + key).textContent = scores[key];
    updateTotal();
  }

  updateTotal();

  // CHECKLIST
  function toggle(li) {
    const box = li.querySelector('.check-box');
    const text = li.querySelector('.check-text');
    box.classList.toggle('done');
    text.classList.toggle('done');
  }

  // TABS
  function switchTab(tabEl, id) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    tabEl.classList.add('active');
    document.getElementById('tab-' + id).classList.add('active');
  }

  // JOURNAL
  let weekNum = 1;
  function addJournalEntry() {
    weekNum++;
    const d = new Date();
    d.setDate(d.getDate() + (weekNum-1)*7);
    const dateStr = d.toLocaleDateString('ru-RU', { day:'numeric', month:'long', year:'numeric' });
    const entry = document.createElement('div');
    entry.className = 'journal-entry';
    entry.innerHTML = `
      <div class="journal-date">ВОСКРЕСЕНЬЕ · ${dateStr} · НЕДЕЛЯ ${weekNum}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);margin-bottom:6px">ЧТО ТРЕВОЖИТ</div>
          <textarea class="journal-input" rows="3" placeholder="Напиши честно..."></textarea>
        </div>
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);margin-bottom:6px">ЧТО КОНТРОЛИРУЮ</div>
          <textarea class="journal-input" rows="3" placeholder="Что в моих руках..."></textarea>
        </div>
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--muted);margin-bottom:6px">1 ДЕЙСТВИЕ ЭТОЙ НЕДЕЛИ</div>
          <textarea class="journal-input" rows="3" placeholder="Одно конкретное..."></textarea>
        </div>
      </div>
    `;
    document.getElementById('journal-entries').appendChild(entry);
    entry.scrollIntoView({ behavior: 'smooth' });
  }
</script>
</body>
</html>
